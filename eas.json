{
	"cli": {
		"version": ">= 16.18.0",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal",
			"env": {
				"EXPO_USE_COMMUNITY_AUTOLINKING": "1"
			}
		},
		"preview": {
			"distribution": "internal",
			"android": {
				"image": "latest"
			}
		},
		"production": {
			"autoIncrement": true
		}
	},
	"submit": {
		"production": {}
	}
}
